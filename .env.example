# TG Canvas config template (do NOT commit real secrets)

# --- Telegram Auth ---
BOT_TOKEN=<telegram_bot_token>
ALLOWED_USER_IDS=<telegram_user_id1,telegram_user_id2>
JWT_SECRET=<32+_bytes_random_secret>
JWT_TTL_SECONDS=900
INIT_DATA_MAX_AGE_SECONDS=300

# --- Canvas Server ---
PORT=3721
TG_CANVAS_URL=https://canvas.example.com
WORKSPACE_ROOT=/home/joker/projects
PUSH_TOKEN=<32+_bytes_random_secret>
MINIAPP_URL=https://canvas.example.com

# Optional instance-local state. Template systemd units set these automatically.
# TG_CANVAS_INSTANCE=main
# TG_CANVAS_DATA_DIR=/home/joker/projects/tg-canvas-studio/var/main
# COMMANDS_FILE=/home/joker/projects/tg-canvas-studio/var/main/commands.json

# --- Quick Commands ---
ALLOW_COMMANDS_WRITE=true
# editable: run command text from UI
# safe: only run fixed mappings/allowlist
COMMAND_EXECUTION_MODE=editable
# Only used when COMMAND_EXECUTION_MODE=safe
COMMAND_RUN_ALLOWLIST=git-status,git-log,openclaw-status,server-logs,check-services

# --- ttyd ---
TTYD_PORT=7681
TTYD_PROXY_PORT=7681
TTYD_WORKDIR=/home/joker/projects

# --- Cloudflared ---
CLOUDFLARED_TUNNEL=canvas-tunnel

# --- OpenClaw Proxy (optional) ---
ENABLE_OPENCLAW_PROXY=false
OPENCLAW_GATEWAY_TOKEN=<openclaw_gateway_token>
OPENCLAW_PROXY_HOST=127.0.0.1
OPENCLAW_PROXY_PORT=18789

# --- PATH for command execution ---
PATH=/home/joker/.npm-global/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
